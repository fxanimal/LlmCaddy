@using Microsoft.AspNetCore.Identity
@{
    ViewData["Title"] = "Log out";
    ViewData["PageLanguage"] = "en";
    Layout = "/Views/Shared/_Layout.cshtml";
    var strDomainname = ViewBag.Domainname;
}

<div class="min-h-[60vh] flex flex-col items-center justify-center px-4">
    <div class="max-w-md w-full bg-white border border-slate-200 rounded-2xl shadow-sm p-8 text-center">

        <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-rose-50 mb-6">
            <span class="text-2xl">🚪</span>
        </div>

        <h1 class="text-3xl font-bold text-slate-900 mb-2">@ViewData["Title"]</h1>

        @{
            if (User.Identity?.IsAuthenticated ?? false)
            {
                <p class="text-slate-600 mb-8">
                    Are you sure you want to end your session on <strong>@strDomainname</strong>?
                </p>

                <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full inline-flex justify-center items-center px-6 py-3 border border-transparent text-base font-medium rounded-xl text-white bg-rose-600 hover:bg-rose-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-rose-500 transition-all duration-200 shadow-sm">
                        Confirm Logout
                    </button>
                </form>

                <a href="/account/dashboard" class="mt-4 inline-block text-sm text-slate-500 hover:text-slate-800 transition">
                    Nevermind, take me back
                </a>
            }
            else
            {
                <p class="text-lg text-slate-600 mb-8">
                    You have successfully logged out of the application.
                </p>

                <div class="space-y-3">
                    <a href="/Account/login"
                       class="w-full inline-flex justify-center items-center px-6 py-3 border border-slate-300 text-base font-medium rounded-xl text-slate-700 bg-white hover:bg-slate-50 transition-all duration-200">
                        Sign In Again
                    </a>

                    <a href="/" class="block text-sm text-cyan-600 hover:text-cyan-700 font-medium">
                        Return to @strDomainname Home
                    </a>
                </div>
            }
        }
    </div>
</div>