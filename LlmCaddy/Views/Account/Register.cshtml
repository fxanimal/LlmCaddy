@model LlmCaddy.Models.RegisterModel
@{
    ViewData["Title"] = "Register";
    ViewData["PageLanguage"] = "en";
    Layout = "/Views/Shared/_Layout.cshtml"; 
    var strDomainname = ViewBag.Domainname;
}

<div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl w-full grid grid-cols-1 md:grid-cols-2 gap-8 bg-white border border-slate-200 rounded-3xl shadow-xl overflow-hidden">

        <div class="p-8 md:p-12">
            <div class="mb-8">
                <h1 class="text-3xl font-extrabold text-slate-900">Get Started</h1>
                <p class="text-slate-500 mt-2">Create your @strDomainname account today.</p>
            </div>

            <form id="registerForm" method="post" class="space-y-5">
                <div asp-validation-summary="ModelOnly" class="p-3 bg-rose-50 text-rose-600 text-sm rounded-lg" role="alert"></div>

                <div>
                    <label asp-for="Email" class="block text-sm font-semibold text-slate-700 mb-1">Email Address</label>
                    <input asp-for="Email"
                           class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 transition-all outline-none placeholder-slate-400"
                           placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-xs text-rose-500 mt-1"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-semibold text-slate-700 mb-1">Password</label>
                    <input asp-for="Password"
                           class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 transition-all outline-none placeholder-password" />
                    <span asp-validation-for="Password" class="text-xs text-rose-500 mt-1"></span>
                </div>

                <div>
                    <label asp-for="ConfirmPassword" class="block text-sm font-semibold text-slate-700 mb-1">Confirm Password</label>
                    <input asp-for="ConfirmPassword"
                           class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 transition-all outline-none placeholder-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-xs text-rose-500 mt-1"></span>
                </div>

                <button id="registerSubmit" type="submit"
                        class="w-full bg-slate-900 hover:bg-black text-white font-bold py-3 px-4 rounded-xl transition duration-200 shadow-lg active:scale-[0.98]">
                    Create Account
                </button>
            </form>

            <p class="mt-8 text-center text-sm text-slate-500">
                Already have an account?
                <a href="/Account/login" class="text-cyan-600 hover:text-cyan-700 font-bold">Sign in</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}