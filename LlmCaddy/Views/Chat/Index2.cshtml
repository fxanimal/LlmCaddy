@model LlmCaddy.Models.IndexViewModel
@using Microsoft.AspNetCore.Http;
@{
    ViewData["Title"] = "LLM Caddy";
    ViewData["PageLanguage"] = "en";
    Layout = "/Views/Shared/_Layout.cshtml";
    var strDomainname = ViewBag.Domainname;
}
@using System.Security.Claims
@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<script>
    (function() {
        const serverUserId = "@userId";

        if (serverUserId && serverUserId.trim() !== "") {
            localStorage.setItem("LlmCaddy_ExplicitClientId", serverUserId);
            window.authenticatedServerUserId = serverUserId;
        } else {
            localStorage.removeItem("LlmCaddy_ExplicitClientId");
            window.authenticatedServerUserId = null;
        }
    })();
</script>

@section SyncSection2 {
    <a id="cloud-purge-btn" href="javascript:void(0);" class="bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg text-sm font-bold transition">Purge Local Database</a>
    <a id="cloud-push-btn" href="javascript:void(0);" class="bg-cyan-600 hover:bg-cyan-500 text-white px-4 py-2 rounded-lg text-sm font-bold transition">Backup to Cloud</a>
    <a id="cloud-restore-btn" href="javascript:void(0);" class="bg-cyan-600 hover:bg-cyan-500 text-white px-4 py-2 rounded-lg text-sm font-bold transition">Restore from Cloud</a>
}

<script>
    window.UserPermissionsConfig = {
        permittedIds: @Html.Raw(Json.Serialize(Model.PermittedProviderIds)),
        customProviders: @Html.Raw(Json.Serialize(Model.PermittedCustomProviders))
    };
</script>

<style>
    .prose h1, .prose h2, .prose h3 { font-weight: 700; margin: 12px 0 6px; color: #1e293b; }
    .prose h2 { font-size: 15px; }
    .prose h3 { font-size: 13px; }
    .prose p  { margin: 6px 0; line-height: 1.6; }
    .prose ul, .prose ol { padding-left: 20px; margin: 6px 0; }
    .prose li { margin: 3px 0; line-height: 1.6; }
    .prose code {
        background: #f1f5f9; color: #0f172a;
        padding: 1px 5px; border-radius: 4px;
        font-family: monospace; font-size: 12px;
    }
    .prose pre {
        background: #0f172a; color: #e2e8f0;
        padding: 12px; border-radius: 8px;
        overflow-x: auto; margin: 8px 0;
    }
    .prose pre code { background: none; color: inherit; padding: 0; }
    .prose strong { font-weight: 600; }
    .prose hr { border: none; border-top: 1px solid #e2e8f0; margin: 12px 0; }
    .prose table { width: 100%; border-collapse: collapse; margin: 8px 0; font-size: 12px; }
    .prose th { background: #f1f5f9; padding: 6px 10px; text-align: left; border: 1px solid #e2e8f0; }
    .prose td { padding: 6px 10px; border: 1px solid #e2e8f0; }
    .prose blockquote { border-left: 3px solid #f97316; padding-left: 12px; color: #64748b; margin: 8px 0; }
</style>
<div class="flex flex-1 h-full w-full bg-slate-50 text-slate-900 overflow-hidden">
    <aside class="w-64 flex-shrink-0 bg-slate-900 text-white flex flex-col">
        <div class="p-4 border-b border-slate-700 font-bold text-xl flex items-center gap-2">
            <span class="text-blue-400">⛳</span> LlmCaddy
        </div>
        <div class="p-4">
            <button onclick="startNewChat()" class="w-full mx-0 mt-2 mb-4 px-3 py-2 bg-blue-600 hover:bg-blue-500 text-white text-xs font-semibold rounded-lg transition-all">
                ✏️ New Chat
            </button>
        </div>
        <div class="p-4 border-t border-slate-800">
            <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Semantic History Search</h3>
            <div class="space-y-2">
                <input type="text" id="searchInput" class="w-full text-slate-900 bg-slate-100 rounded p-2 text-xs focus:outline-none" placeholder="Type meaning (e.g., 'errors about tokens')...">
                <button class="w-full px-3 py-2 bg-slate-700 hover:bg-slate-600 text-white text-xs font-semibold rounded transition-all" id="searchBtn" type="button" onclick="handleSemanticSearch()">🔍 Search Analytics</button>
            </div>
            <ul id="resultsList" class="list-group mt-2 max-h-40 overflow-y-auto custom-scrollbar"></ul>
        </div>
        <div class="p-3 text-slate-400 text-[11px] uppercase tracking-wider font-semibold">
            Conversation Stream
        </div>
        <nav class="flex-1 overflow-y-auto px-2 pb-4 custom-scrollbar">
            <ul id="chat-history-sidebar-list" class="space-y-1 text-sm text-slate-300">
            </ul>
        </nav>
        <div class="p-4 border-t border-slate-800 flex justify-between items-center bg-slate-950">
            <div id="db-status-badge" class="text-[10px] text-slate-400 font-medium">SQLite: Verifying...</div>
            <button onclick="exportDatabase()" class="px-2 py-1 bg-slate-700 text-white text-[10px] font-semibold rounded hover:bg-slate-600 transition-all">
                ⬇ Export DB
            </button>
        </div>
    </aside>

    <main class="flex-1 flex flex-col bg-white min-h-0">
        <div id="db-info-alert" class="max-w-md mx-auto my-4 p-4 rounded-xl text-sm border flex items-center gap-3 transition-all duration-300 bg-blue-50 border-blue-200 text-blue-800">
            <div id="alert-icon" class="text-base">⏳</div>
            <div class="flex-1">
                <span id="alert-title" class="font-bold">Database Initializing:</span>
                <span id="alert-message">Downloading sqlite.wasm files and opening local storage engine...</span>
            </div>
        </div>

        <header class="h-16 border-b flex items-center bg-white/80 backdrop-blur-md sticky top-0 z-10 px-6">
            <div class="max-w-7xl mx-auto w-full flex justify-between items-center">
                <h2 class="font-semibold text-slate-700">Current Session</h2>
                <div class="flex items-center gap-3">
                    <div id="model-badges" class="flex items-center gap-2 flex-wrap justify-end"></div>
                    <button data-action="add-provider" class="px-2 py-1 bg-slate-800 text-white text-xs font-semibold rounded hover:bg-slate-700 transition-all">
                        ➕ Add
                    </button>
                </div>
            </div>
        </header>

        <section class="flex-1 overflow-y-auto p-6 bg-slate-50/50">
            <div id="chatHistory" class="w-full space-y-8"></div>
        </section>

        <footer class="p-4 bg-white border-t sticky bottom-0 left-0 right-0 z-20">
            <div id="fileChips" class="flex flex-wrap gap-2 mb-2"></div>

            <div class="w-full flex items-end gap-2 bg-slate-50 border rounded-xl p-2">
                <input type="file" id="fileInput" accept=".pdf,.docx,.txt" multiple class="hidden" />
                <button id="attachBtn" onclick="document.getElementById('fileInput').click()"
                        class="flex-shrink-0 p-3 text-slate-500 hover:text-blue-600 hover:bg-slate-100 rounded-lg transition-all"
                        title="Attach file">
                    📎
                </button>
                <textarea id="chatInput" class="flex-1 p-3 bg-transparent border-none focus:outline-none resize-none text-sm"
                          rows="1" placeholder="Ask LlmCaddy anything... (paste text or attach a file)"></textarea>
                <button id="sendBtn" onclick="handleSendQuery()"
                        class="flex-shrink-0 p-3 bg-blue-600 hover:bg-blue-500 text-white rounded-lg transition-all">
                    ➤
                </button>
            </div>
            <p class="text-center text-[10px] text-slate-400 mt-2">
                LLMs can make mistakes.
            </p>
        </footer>
    </main>
</div>
<script src="/js/chat2.js" type="module" asp-append-version="true"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/marked/9.1.6/marked.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/mammoth@1.6.0/mammoth.browser.min.js"></script>